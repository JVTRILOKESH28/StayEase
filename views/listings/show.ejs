<% layout("layouts/boilerplate") %>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                <img
                    src="<%= foundlisting.image.url %>"
                    class="card-img-top"
                    alt="Listing Image"
                    style="height:450px; object-fit:cover;"
                >

                <div class="card-body p-4">

                    <h2 class="fw-bold mb-3">
                        <%= foundlisting.title %>
                    </h2>

                    <p class="text-muted">
                        <i class="fa-solid fa-location-dot"></i>
                        <%= foundlisting.location %>,
                        <%= foundlisting.country %>
                    </p>

                    <hr>

                    <p class="fs-5">
                        <%= foundlisting.description %>
                    </p>

                    <h4 class="text-danger fw-bold mt-4">
                        ₹ <%= foundlisting.price %> / night
                    </h4>

                    <div class="d-flex gap-3 mt-4">

                        <a
                            href="/listings/<%= foundlisting._id %>/edit"
                            class="btn btn-primary"
                        >
                            Edit
                        </a>

                        <form
                            method="POST"
                            action="/listings/<%= foundlisting._id %>?_method=DELETE"
                        >
                            <button
                                type="submit"
                                class="btn btn-danger"
                            >
                                Delete
                            </button>
                        </form>

                    </div>

                </div>
            </div>
            <!-- Review Form -->

<div class="card shadow-sm border-0 rounded-4 mt-5">
    <div class="card-body p-4">

        <h3 class="mb-4">Leave a Review</h3>

        <form
            method="POST"
            action="/listings/<%= foundlisting._id %>/reviews"
            class="needs-validation"
            novalidate
        >

            <div class="mb-3">
                <label class="form-label">
                    Rating
                </label>

                <select
                    name="review[rating]"
                    class="form-select"
                    required
                >
                    <option value="">
                        Choose Rating
                    </option>

                    <option value="1">⭐ 1</option>
                    <option value="2">⭐⭐ 2</option>
                    <option value="3">⭐⭐⭐ 3</option>
                    <option value="4">⭐⭐⭐⭐ 4</option>
                    <option value="5">⭐⭐⭐⭐⭐ 5</option>
                </select>

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Comment
                </label>

                <textarea
                    name="review[comment]"
                    class="form-control"
                    rows="4"
                    required
                ></textarea>

            </div>

            <button
                type="submit"
                class="btn btn-success"
            >
                Submit Review
            </button>

        </form>

    </div>
</div>

        </form>
        <h4><i><b>Reviews</b></i></h4>
<% if(foundlisting.reviews.length > 0){ %>

  <% for(let review of foundlisting.reviews){ %>
    
    <div class="card mb-3" style="width: 18rem;">
      <div class="card-body">
        <p class="card-subtitle text-body-secondary">
          Review ID: <%= review._id %>
        </p>
        
        <h5 class="card-title mt-3">
          ⭐ Rating: <%= review.rating %>/5
        </h5>

        <p class="card-text">
          <%= review.comment %>
        </p>

        <form
            method="POST"
            action="/listings/<%= foundlisting._id %>/reviews/<%= review._id %>?_method=DELETE"
            class="d-inline"
        >
            <button
                type="submit"
                class="btn btn-danger"
            >
                Delete
            </button>
        </form>
      </div>
    </div>

  <% } %>

<% } else { %>

  <p class="text-muted">No reviews yet</p>

<% } %>
</div>

        </div>

    </div>
</div>